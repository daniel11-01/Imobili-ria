NODE_ENV=production
PORT=3000
FRONTEND_URL=https://teudominio.pt

# Pasta fisica onde as imagens vao ser guardadas no cPanel.
# Exemplo comum: /home/UTILIZADOR/public_html/images
UPLOADS_ROOT=/home/UTILIZADOR/public_html/images

# Caminho publico usado nas URLs das imagens
UPLOADS_PUBLIC_PATH=/images

# Dominio publico para as imagens (opcional mas recomendado no cPanel)
UPLOADS_PUBLIC_BASE_URL=https://teudominio.pt

DB_HOST=localhost
DB_PORT=3306
DB_NAME=imobiliaria_db
DB_USER=cpanel_db_user
DB_PASSWORD=cpanel_db_password
DB_CONNECT_TIMEOUT_MS=20000
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_LOGGING=false

JWT_SECRET=trocar_por_chave_forte_muito_grande
JWT_EXPIRES_IN=24h
AUTH_COOKIE_NAME=imobiliaria_auth
CSRF_COOKIE_NAME=imobiliaria_csrf
CSRF_HEADER_NAME=x-csrf-token
JWT_COOKIE_MAX_AGE_MS=86400000
FRONTEND_RESET_PASSWORD_URL=https://teudominio.pt/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_FORGOT_RATE_LIMIT_MAX=5
AUTH_RESET_RATE_LIMIT_MAX=8
PASSWORD_RESET_CLEANUP_AGE_HOURS=48
PASSWORD_RESET_CLEANUP_INTERVAL_MS=600000

ADMIN_BOOTSTRAP_FIRST_NAME=Admin
ADMIN_BOOTSTRAP_LAST_NAME=Principal
ADMIN_BOOTSTRAP_EMAIL=admin@teudominio.pt
ADMIN_BOOTSTRAP_PASSWORD=Admin12345

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Imobiliaria Site
SMTP_FROM_EMAIL=no-reply@teudominio.pt

RECAPTCHA_ENABLED=true
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
