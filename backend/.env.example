NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_NAME=imobiliaria_db
DB_USER=root
DB_PASSWORD=
DB_LOGGING=false

JWT_SECRET=trocar_esta_chave_em_producao
JWT_EXPIRES_IN=24h
AUTH_COOKIE_NAME=imobiliaria_auth
JWT_COOKIE_MAX_AGE_MS=86400000
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_FORGOT_RATE_LIMIT_MAX=5
AUTH_RESET_RATE_LIMIT_MAX=8
PASSWORD_RESET_CLEANUP_AGE_HOURS=48
PASSWORD_RESET_CLEANUP_INTERVAL_MS=600000

ADMIN_BOOTSTRAP_FIRST_NAME=Admin
ADMIN_BOOTSTRAP_LAST_NAME=Principal
ADMIN_BOOTSTRAP_EMAIL=admin@imobiliaria.local
ADMIN_BOOTSTRAP_PASSWORD=Admin12345

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Imobiliaria Site
SMTP_FROM_EMAIL=no-reply@imobiliaria.local

RECAPTCHA_ENABLED=true
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
