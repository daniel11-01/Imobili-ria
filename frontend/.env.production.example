# URL da API publicada no cPanel (subdominio ou proxy /api)
VITE_API_BASE_URL=https://api.teudominio.pt/api

# URL publica do site para links de partilha
VITE_PUBLIC_SITE_URL=https://teudominio.pt

# reCAPTCHA v2/v3 site key publica
VITE_RECAPTCHA_SITE_KEY=

# Deve corresponder ao backend (opcional se usares default)
VITE_CSRF_HEADER_NAME=x-csrf-token
